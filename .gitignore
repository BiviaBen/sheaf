# Local dev / wp-env
.wp-env.override.json

# Dependencies & build artifacts (regenerated, never committed)
node_modules/
vendor/
build/

# Exception: plugin-update-checker is vendored into the plugin and ships with
# it, including the library's own bundled vendor/ (Parsedown + readme parser).
!plugins/sheaf/lib/plugin-update-checker/vendor/
!plugins/sheaf/lib/plugin-update-checker/vendor/**

# Playwright E2E (browsers, reports, saved auth — all regenerated)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
tests/e2e/.auth/

# Logs & OS/editor cruft
*.log
.DS_Store
Thumbs.db
.idea/
.vscode/
